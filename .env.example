# BM Group — environment variables
# Copy this file to .env.local and fill in real values before running `npm run dev`.

# === Database (libSQL / Turso) ===
# Default = local file under ./data/. For production, point to a Turso DB:
#   DATABASE_URL=libsql://<your-db>.turso.io
DATABASE_URL=file:./data/bmgroup.db
# Required only when DATABASE_URL is a remote libSQL/Turso instance.
# DATABASE_AUTH_TOKEN=

# === Admin auth ===
# The single admin account allowed to log in to /admin.
ADMIN_EMAIL=admin@bmgroup.tn
# Bcrypt hash of the admin password (NOT the password itself).
# IMPORTANT: Next.js runs variable expansion on `.env*` files. Every literal `$`
# in the bcrypt string must be escaped as `\$`, otherwise the hash becomes empty.
# Generate with:
#   node -e "require('bcryptjs').hash('testpassword', 10).then(h => console.log(h))"
# Then paste with each $ doubled as \$ (e.g. \$2b\$10\$.....).
ADMIN_PASSWORD_HASH=\$2b\$10\$replace-with-the-hash-you-just-generated

# Random >=32-character secret used to sign admin session JWTs.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=

# === Optional ===
# Google Analytics 4 — Measurement ID (Admin -> Data streams -> Web -> Measurement ID).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Search Console — HTML tag verification (Settings -> Ownership verification -> HTML tag).
GOOGLE_SITE_VERIFICATION=your_verification_token_only
